PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Bounded / reliable pools
WORKER_POOL_WORKERS=4
WORKER_POOL_QUEUE_SIZE=32

# Advanced pool (separate sizing for lab comparison)
WORKER_POOL_ADVANCED_WORKERS=8
WORKER_POOL_ADVANCED_QUEUE_SIZE=64

# Simulated task duration (ms)
TASK_SIMULATE_MS=50

# Naive: simulate | ffmpeg (lavfi) | upload (POST /work/naive/upload with form field video=@file)
NAIVE_MODE=simulate
FFMPEG_PATH=ffmpeg
# Relative to process cwd (with `make dev` that is 03-worker-pool/go/, not repo root)
NAIVE_FFMPEG_WORKDIR=tmp/naive-ffmpeg
# Optional: RTSP/file URL for one-second grab (empty = synthetic testsrc, no camera needed)
# NAIVE_FFMPEG_INPUT=rtsp://user:pass@camera:554/stream
# With input: set 1 for -c copy (output .ts)
# NAIVE_FFMPEG_STREAM_COPY=0

# Pool: simulate | ffmpeg (lavfi) | upload (POST /work/bounded/upload etc.)
# POOL_TASK_MODE=simulate
# POOL_FFMPEG_WORKDIR=tmp/pool-ffmpeg
# Real video: originals and transcoded H.264 (GET /work/result/{job_id})
# VIDEO_UPLOAD_DIR=tmp/video-uploads
# VIDEO_OUTPUT_DIR=tmp/video-outputs
# UPLOAD_MAX_MB=200
# HTTP_READ_TIMEOUT_SEC=600
# HTTP_WRITE_TIMEOUT_SEC=600
